{
  "meta": { "name": "claude-code-custom" },
  "extends": "claude-code",
  "filesystem": {
    "read": [
	    "/opt/claude-code",
	    "/usr/include",
	    "$HOME/.config/jj",
	    "$HOME/.config/npm"
    ],
    "read_file": [
	    "$HOME/.gitignore",
	    "$HOME/.ssh/id_ed25519.pub",
	    "/etc/passwd",
	    "/proc/1/mountinfo"
    ],
    "allow": [
	    "$HOME/.cargo",
	    "$HOME/.npm",
	    "$HOME/.cache/pre-commit"
    ],
    "allow_file": [
	    "$HOME/.claude.json"
    ]
  },
  "workdir": {
	  "access": "readwrite"
  }
}
